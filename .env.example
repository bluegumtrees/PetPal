# ---- LLM / VLM via OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VLM_MODEL=openai/gpt-4o-mini
LLM_MODEL=openai/gpt-4o-mini

# ---- Maps (P5) ----
AMAP_KEY=

# ---- Email alerts (P6.2) ----
# 全部留空 → dry-run 模式（控制台打印邮件内容，db 标 channel=dry_run）
# 适合开发 / 演示。V2 才会真发到用户邮箱（届时加 user 表 + email 字段）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_TO=

# ---- App ----
APP_ENV=dev

# ---- Dev mode (P6.2) ----
# 设为 1 才能用 /api/reminders/{id}/trigger_now 立即触发演示
# 生产部署一定要去掉或设 0
PETPAL_DEV_MODE=1
